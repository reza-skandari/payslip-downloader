# Copy this file to .env and fill in your values.
# Never commit .env to version control — it is in .gitignore.

# The URL of your HR/payroll portal (will redirect to Microsoft login).
PAYROLL_URL=https://your-portal.example.com

# Your Microsoft 365 email — used to pre-fill the login page only.
# Password is NOT stored here; you type it manually in the browser.
MS365_USERNAME=your.email@example.com

# Optional: where to save downloaded payslips (default: ./payslips)
# DOWNLOAD_DIR=./payslips
